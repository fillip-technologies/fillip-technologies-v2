# MongoDB connection string (Atlas, or any MongoDB host). Primary datastore.
# Atlas -> Cluster -> Connect -> Drivers -> copy the "mongodb+srv://…" string.
# Include a database name in the path, e.g. .../fillip?retryWrites=true&w=majority
MONGODB_URI=


SESSION_SECRET=


# Shared secret for the external leads API (GET /api/integrations/leads).
# Set this to a long random string and give it to the platform that pulls
# leads; it sends it as `Authorization: Bearer <key>` or an `x-api-key` header.
# Leave blank to disable that endpoint entirely (returns 503). This is separate
# from the admin login — rotate/revoke it without affecting the dashboard.
LEADS_API_KEY=

# DANGER: set to "true" to make GET /api/integrations/leads fully public — no
# key required, anyone who can reach the URL reads all lead PII. Leave unset for
# key-protected access. Revoke public access by removing this / setting it false.
LEADS_API_PUBLIC=


# --- Email (SMTP) ---------------------------------------------------------
# Used to email quote PDFs to clients and to notify the team of new leads /
# quote requirements. If these are unset, mail is skipped (leads are still
# saved and visible in the admin).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Optional "From" header; defaults to "Fillip Technologies … <SMTP_USER>".
SMTP_FROM=

# All lead + quote notifications go to the single company inbox defined by
# COMPANY.email in src/data/pricing.ts (no separate recipient env vars).


