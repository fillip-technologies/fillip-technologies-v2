# MongoDB connection string (Atlas, or any MongoDB host). Primary datastore.
# Atlas -> Cluster -> Connect -> Drivers -> copy the "mongodb+srv://…" string.
# Include a database name in the path, e.g. .../fillip?retryWrites=true&w=majority
MONGODB_URI=

# Legacy Postgres connection string — only needed to run the one-time
# `npm run db:migrate-from-postgres` data migration. Safe to remove afterwards.
DATABASE_URL=

# Optional: comma-separated DNS resolvers. Set only if your network refuses the
# SRV lookups that mongodb+srv:// needs (symptom: "querySrv ECONNREFUSED").
# DNS_SERVERS=8.8.8.8,1.1.1.1

# Secret used to sign admin session cookies (JWT). Generate a strong random value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=


# --- Email (SMTP) ---------------------------------------------------------
# Used to email quote PDFs to clients and to notify the team of new leads /
# quote requirements. If these are unset, mail is skipped (leads are still
# saved and visible in the admin).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Optional "From" header; defaults to "Fillip Technologies … <SMTP_USER>".
SMTP_FROM=

# All lead + quote notifications go to the single company inbox defined by
# COMPANY.email in src/data/pricing.ts (no separate recipient env vars).


